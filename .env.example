NODE_ENV=development
APP_URL=http://127.0.0.1:3000
API_URL=http://127.0.0.1:3001
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/rip
BETTER_AUTH_SECRET=replace-with-a-long-dev-secret-value
BETTER_AUTH_URL=http://127.0.0.1:3000
PORT=3001
DOWNLOAD_DIR=~/Downloads/Rip
MAX_CONCURRENT_DOWNLOADS=3
MAX_INCOMPLETE_DOWNLOADS=50
YTDLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg
TRUSTED_PROXY_HOSTS=
REQUEST_BODY_LIMIT_BYTES=1048576
COMPLETED_EXPIRY_SECONDS=3600
