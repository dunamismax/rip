{
  "name": "@rip/workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @rip/web dev",
    "build": "pnpm --filter @rip/contracts build && pnpm --filter @rip/db build && pnpm --filter @rip/web build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "check": "pnpm -r check",
    "db:generate": "pnpm --filter @rip/db db:generate",
    "db:migrate": "pnpm --filter @rip/db db:migrate",
    "db:push": "pnpm --filter @rip/db db:push",
    "db:studio": "pnpm --filter @rip/db db:studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
