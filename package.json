{
  "name": "rip",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -c \"#f59e0b,#0ea5e9\" \"\\\"$npm_execpath\\\" run dev:api\" \"\\\"$npm_execpath\\\" run dev:web\" --names=api,web",
    "dev:api": "\"$npm_execpath\" run --watch backend/index.ts",
    "dev:web": "react-router dev --port 3000",
    "build": "react-router build",
    "start": "concurrently -c \"#f59e0b,#0ea5e9\" \"\\\"$npm_execpath\\\" run start:api\" \"\\\"$npm_execpath\\\" run start:web\" --names=api,web",
    "start:api": "\"$npm_execpath\" run backend/index.ts",
    "start:web": "\"$npm_execpath\" run scripts/start-web.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "react-router typegen && tsc",
    "doctor": "\"$npm_execpath\" run scripts/cli.ts doctor",
    "smoke": "\"$npm_execpath\" run scripts/smoke.ts"
  },
  "dependencies": {
    "@react-router/node": "^7.13.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "hono": "^4.12.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "isbot": "^5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@react-router/dev": "^7.13.1",
    "@react-router/serve": "^7.13.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
